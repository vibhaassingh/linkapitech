# Analytics (env-driven only — never hardcode a measurement ID). Leave blank to disable.
NEXT_PUBLIC_ANALYTICS_ID=

# Public site origin, used for absolute OG/canonical URLs and sitemap.
NEXT_PUBLIC_SITE_URL=https://linkapitech.com

# Contact form delivery (server-side). Wire one real handler before launch.
# Example: a Resend API key + destination inbox. Left blank => the API route
# logs the submission and returns success (dev-safe, no external calls).
CONTACT_TO_EMAIL=partnership@linkapitech.com
RESEND_API_KEY=
